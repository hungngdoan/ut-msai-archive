---
import type { Project } from '../lib/collections';
import StatusPill from './StatusPill.astro';
import { href } from '../lib/url';

interface Props {
  project: Project;
}
const { project } = Astro.props;
const d = project.data;
---

<a href={href(`/projects/${project.id}`)} class="card card-link block p-5 h-full">
  <div class="flex items-start justify-between gap-3 mb-2">
    <h3 class="text-lg leading-tight">{d.title}</h3>
    <StatusPill status={d.status} />
  </div>
  <p class="text-sm text-[var(--color-ink-300)] leading-relaxed line-clamp-3">{d.summary}</p>
  <div class="mt-4 flex flex-wrap gap-1.5">
    {d.stack.slice(0, 4).map((s) => <span class="chip">{s}</span>)}
  </div>
  <div class="mt-4 flex items-center gap-3 font-mono text-[0.7rem] text-[var(--color-ink-500)]">
    {d.portfolioSafe && <span class="text-[var(--color-status-done)]">◆ portfolio-safe</span>}
    {d.courses.length > 0 && <span>· {d.courses.join(' / ')}</span>}
  </div>
</a>
